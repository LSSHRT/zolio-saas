# Security-critical variables introduced by the hardening patch.
# Copy these into .env.local or your hosting provider dashboard and set real values.

PUBLIC_DEVIS_LINK_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com
# Required for automated lead discovery in /api/cron/prospect.
HUNTER_API_KEY=replace-with-your-hunter-api-key

# Dedicated sender for outbound prospecting.
# Do not use a personal Gmail mailbox for cold outreach.
PROSPECT_SMTP_HOST=smtp.mailprovider.com
PROSPECT_SMTP_PORT=587
PROSPECT_SMTP_USER=hello@your-domain.com
PROSPECT_SMTP_PASS=replace-with-a-dedicated-password
PROSPECT_FROM_EMAIL=hello@your-domain.com
PROSPECT_REPLY_TO=hello@your-domain.com
PROSPECT_UNSUBSCRIBE_URL=https://zolio.site/unsubscribe
PROSPECT_AUTOSEND_ENABLED=false
PROSPECT_COOLDOWN_DAYS=60
# Hard cap once the mailbox is warmed up.
PROSPECT_DAILY_LIMIT=10
