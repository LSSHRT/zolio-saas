datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Client {
  id             String               @id @default(cuid())
  userId         String
  nom            String
  email          String?
  telephone      String?
  adresse        String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  devis          Devis[]
  facturesRecurrentes FactureRecurrente[]

  @@index([userId])
}

model Prestation {
  id          String    @id @default(cuid())
  userId      String
  nom         String
  description String?
  unite       String?
  prix        Decimal   @db.Decimal(10, 2)
  cout        Decimal?  @default(0) @db.Decimal(10, 2)
  stock       Int?      @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([userId])
}

model Devis {
  id            String       @id @default(cuid())
  userId        String
  numero        String
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id])
  date          DateTime     @default(now())
  statut        String       @default("En attente") // En attente, Accepté, Refusé, Annulé, Facturé, Payé
  remise        Decimal?     @default(0) @db.Decimal(10, 2)
  acompte       Decimal?     @default(0) @db.Decimal(10, 2)
  tva           Decimal?     @default(0) @db.Decimal(10, 2)
  signature     String?      // URL de la signature image (migré depuis base64)
  signedBy      String?      // Nom du signataire
  signatureIp   String?      // IP du signataire
  signatureUserAgent String? // User-agent du signataire
  signatureDate DateTime?    // Date de signature
  totalHT        Decimal       @default(0) @db.Decimal(10, 2)
  totalTTC       Decimal       @default(0) @db.Decimal(10, 2)
  lignesNorm     LigneDevis[] // Lignes normalisées
  photos        Json?        // Array of photo URLs
  tags          Json?        // Array de tags (ex: ["urgent", "récurrent"])
  notes         String?      // Notes internes sur le devis
  dateDebut     DateTime?
  dateFin       DateTime?
  factures      Facture[]    // Factures générées depuis ce devis
  optionLabel   String?      // Label de l'option : "basique", "standard", "premium"
  devisParentId String?      // Lien vers le devis parent (groupe d'options)
  devisParent   Devis?       @relation("DevisOptions", fields: [devisParentId], references: [id], onDelete: SetNull)
  devisOptions  Devis[]      @relation("DevisOptions")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@unique([userId, numero])
  @@index([userId, statut])
  @@index([userId, createdAt])
}

model LigneDevis {
  id             String   @id @default(cuid())
  devisId        String
  devis          Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)
  nomPrestation  String
  unite          String   @default("U")
  quantite       Decimal  @default(1) @db.Decimal(10, 2)
  prixUnitaire   Decimal  @default(0) @db.Decimal(10, 2)
  totalLigne     Decimal  @default(0) @db.Decimal(10, 2)
  tva            String   @default("20")
  isOptional     Boolean  @default(false)
  position       Int      @default(0) // Ordre d'affichage
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([devisId])
}

model Depense {
  id          String    @id @default(cuid())
  userId      String
  description String
  montant     Decimal   @db.Decimal(10, 2)
  date        DateTime  @default(now())
  categorie   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([userId])
}

model Facture {
  id                    String             @id @default(cuid())
  userId                String
  numero                String
  devisId               String?            // Lien vers le devis source
  devis                 Devis?             @relation(fields: [devisId], references: [id], onDelete: SetNull)
  recurrenteId          String?            // Lien vers facture récurrente
  recurrente            FactureRecurrente? @relation(fields: [recurrenteId], references: [id], onDelete: SetNull)
  nomClient             String
  emailClient           String?
  totalHT               Decimal            @db.Decimal(10, 2)
  tva                   Decimal            @db.Decimal(10, 2)
  totalTTC              Decimal            @db.Decimal(10, 2)
  statut                String             @default("Émise") // Émise, Payée, En retard, Annulée
  date                  DateTime           @default(now())
  dateEcheance          DateTime?          // Date limite de paiement
  stripePaymentLink     String?            // Lien de paiement Stripe Checkout
  stripeSessionId       String?            // Session Stripe pour suivi
  derniereRelanceNiveau Int                @default(0) // 0=aucune, 1=doux(J+3), 2=ferme(J+7), 3=mise en demeure(J+15)
  derniereRelanceDate   DateTime?          // Date du dernier envoi de relance
  notes                 String?            // Notes internes sur la facture
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  deletedAt             DateTime?

  @@unique([userId, numero])
  @@index([devisId])
  @@index([userId, statut])
  @@index([userId, createdAt])
  @@index([userId, dateEcheance])
  @@index([recurrenteId])
}

model Note {
  id        String    @id @default(cuid())
  userId    String
  titre     String
  contenu   String
  categorie String?   // Chantier, Personnel, Idée, À faire
  couleur   String?   // violet, emerald, rose, amber
  epingle   Boolean   @default(false)
  date      DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([categorie])
}

model ProspectMail {
  id        String   @id @default(cuid())
  email     String
  status    String   @default("Sent") // Sent, Failed, Bounced, Opened, Queued, Blocked
  source    String   @default("Manual") // Manual, Automated
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model ProspectDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  company   String?  // Nom de l'entreprise
  trade     String?  // Métier (peintre, plombier...)
  city      String?  // Ville
  source    String   @default("Manual") // Manual, Automated
  used      Boolean  @default(false) // Déjà utilisé par le robot
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([used])
  @@index([trade])
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Templates de devis ───

model DevisTemplate {
  id          String          @id @default(cuid())
  userId      String
  nom         String          // Nom du modèle (ex: "Rénovation salle de bain")
  description String?
  lignes      LigneTemplate[] // Lignes du modèle
  tva         Decimal         @default(20) @db.Decimal(10, 2)
  remise      Decimal         @default(0) @db.Decimal(10, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([userId])
}

model LigneTemplate {
  id            String        @id @default(cuid())
  templateId    String
  template      DevisTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  nomPrestation String
  unite         String        @default("U")
  quantite      Decimal       @default(1) @db.Decimal(10, 2)
  prixUnitaire  Decimal       @default(0) @db.Decimal(10, 2)
  tva           String        @default("20")
  isOptional    Boolean       @default(false)
  position      Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([templateId])
}

// ─── Factures récurrentes ───

model FactureRecurrente {
  id            String    @id @default(cuid())
  userId        String
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  nom           String    // Nom du contrat (ex: "Entretien mensuel")
  montantHT     Decimal   @db.Decimal(10, 2)
  tva           Decimal   @default(20) @db.Decimal(10, 2)
  montantTTC    Decimal   @db.Decimal(10, 2)
  frequence     String    // "mensuel", "trimestriel", "annuel"
  jourMois      Int       @default(1) // Jour du mois pour la facturation (1-28)
  prochaineDate DateTime  // Date de la prochaine facture
  dateFin       DateTime? // Date de fin (null = illimité)
  actif         Boolean   @default(true)
  description   String?
  factures      Facture[] // Factures générées
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([userId])
  @@index([prochaineDate])
  @@index([actif])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "devis_signed" | "facture_paid" | "devis_overdue" | "client_added" | "milestone" | "system"
  title       String
  description String
  href        String?  // Lien vers la page concernée
  tone        String   @default("violet") // "violet" | "rose" | "amber" | "emerald" | "slate"
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── Événements manuels du planning ───

model CalendarEvent {
  id        String   @id @default(cuid())
  userId    String
  titre     String   // "RDV Chantier", "Rappel", etc.
  date      DateTime // Date de l'événement
  heure     String?  // Optionnel (ex: "14:00")
  type      String   @default("rdv") // "rdv" | "rappel" | "note" | "echeance"
  couleur   String   @default("violet") // "violet" | "emerald" | "amber" | "rose" | "blue"
  notes     String?  // Détails
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
}

// ─── Logs d'Audit ───

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "CREATE", "UPDATE", "DELETE", "RESTORE"
  entity    String   // "Client", "Devis", "Facture", etc.
  entityId  String
  details   Json?    // Détails des changements effectués
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── Utilisateurs synchronisés depuis Clerk ───

model User {
  id        String   @id // L'ID Clerk
  email     String   @unique
  nom       String?
  prenom    String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
