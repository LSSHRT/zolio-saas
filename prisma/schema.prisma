datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  nom       String
  email     String?
  telephone String?
  adresse   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  devis     Devis[]

  @@index([userId])
}

model Prestation {
  id          String   @id @default(cuid())
  userId      String
  nom         String
  description String?
  unite       String?
  prix        Float
  cout        Float?   @default(0) // Cost price for margin
  stock       Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Devis {
  id          String       @id @default(cuid())
  userId      String
  numero      String
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id])
  date        DateTime     @default(now())
  statut      String       @default("En attente") // En attente, Accepté, Refusé, Annulé, Facturé, Payé
  remise      Float?       @default(0)
  acompte     Float?       @default(0)
  tva         Float?       @default(0)
  signature   String?      // Base64 signature image
  lignes      Json?        // @deprecated — migré vers LigneDevis
  lignesNorm  LigneDevis[] // Lignes normalisées
  photos      Json?        // Array of photo base64 strings
  dateDebut   DateTime?
  dateFin     DateTime?
  factures    Facture[]    // Factures générées depuis ce devis
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, numero])
}

model LigneDevis {
  id             String @id @default(cuid())
  devisId        String
  devis          Devis  @relation(fields: [devisId], references: [id], onDelete: Cascade)
  nomPrestation  String
  unite          String @default("U")
  quantite       Float  @default(1)
  prixUnitaire   Float  @default(0)
  totalLigne     Float  @default(0)
  tva            String @default("20")
  isOptional     Boolean @default(false)
  position       Int    @default(0) // Ordre d'affichage
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([devisId])
}

model Depense {
  id          String   @id @default(cuid())
  userId      String
  description String
  montant     Float
  date        DateTime @default(now())
  categorie   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Facture {
  id          String   @id @default(cuid())
  userId      String
  numero      String
  devisId     String?  // Lien vers le devis source
  devis       Devis?   @relation(fields: [devisId], references: [id], onDelete: SetNull)
  devisRef    String?  // @deprecated - Ancien champ texte, gardé pour migration
  nomClient   String
  emailClient String?
  totalHT     Float
  tva         Float
  totalTTC    Float
  statut      String   @default("Émise") // Émise, Payée, En retard
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, numero])
  @@index([devisId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  titre     String
  contenu   String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ProspectMail {
  id        String   @id @default(cuid())
  email     String
  status    String   @default("Sent") // Sent, Failed, Bounced
  source    String   @default("Manual") // Manual, Automated
  createdAt DateTime @default(now())
}

model ProspectDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  company   String?  // Nom de l'entreprise
  trade     String?  // Métier (peintre, plombier...)
  city      String?  // Ville
  source    String   @default("Manual") // Manual, Automated
  used      Boolean  @default(false) // Déjà utilisé par le robot
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([used])
  @@index([trade])
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}
