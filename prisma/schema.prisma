datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Client {
  id             String               @id @default(cuid())
  userId         String
  nom            String
  email          String?
  telephone      String?
  adresse        String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  devis          Devis[]
  facturesRecurrentes FactureRecurrente[]

  @@index([userId])
}

model Prestation {
  id          String   @id @default(cuid())
  userId      String
  nom         String
  description String?
  unite       String?
  prix        Float
  cout        Float?   @default(0) // Cost price for margin
  stock       Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Devis {
  id          String       @id @default(cuid())
  userId      String
  numero      String
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id])
  date        DateTime     @default(now())
  statut      String       @default("En attente") // En attente, Accepté, Refusé, Annulé, Facturé, Payé
  remise      Float?       @default(0)
  acompte     Float?       @default(0)
  tva         Float?       @default(0)
  signature   String?      // Base64 signature image
  lignes      Json?        // @deprecated — migré vers LigneDevis
  lignesNorm  LigneDevis[] // Lignes normalisées
  photos      Json?        // Array of photo base64 strings
  tags        Json?        // Array de tags (ex: ["urgent", "récurrent"])
  notes         String?       // Notes internes sur le devis
  dateDebut     DateTime?
  dateFin       DateTime?
  factures      Facture[]     // Factures générées depuis ce devis
  optionLabel   String?       // Label de l'option : "basique", "standard", "premium"
  devisParentId String?       // Lien vers le devis parent (groupe d'options)
  devisParent   Devis?        @relation("DevisOptions", fields: [devisParentId], references: [id], onDelete: SetNull)
  devisOptions  Devis[]       @relation("DevisOptions")
  createdAt     DateTime      @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, numero])
  @@index([userId, statut])
  @@index([userId, createdAt])
}

model LigneDevis {
  id             String @id @default(cuid())
  devisId        String
  devis          Devis  @relation(fields: [devisId], references: [id], onDelete: Cascade)
  nomPrestation  String
  unite          String @default("U")
  quantite       Float  @default(1)
  prixUnitaire   Float  @default(0)
  totalLigne     Float  @default(0)
  tva            String @default("20")
  isOptional     Boolean @default(false)
  position       Int    @default(0) // Ordre d'affichage
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([devisId])
}

model Depense {
  id          String   @id @default(cuid())
  userId      String
  description String
  montant     Float
  date        DateTime @default(now())
  categorie   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Facture {
  id                String              @id @default(cuid())
  userId            String
  numero            String
  devisId           String?             // Lien vers le devis source
  devis             Devis?              @relation(fields: [devisId], references: [id], onDelete: SetNull)
  devisRef          String?             // @deprecated - Ancien champ texte, gardé pour migration
  recurrenteId      String?             // Lien vers facture récurrente
  recurrente        FactureRecurrente?  @relation(fields: [recurrenteId], references: [id], onDelete: SetNull)
  nomClient         String
  emailClient       String?
  totalHT           Float
  tva               Float
  totalTTC          Float
  statut            String              @default("Émise") // Émise, Payée, En retard, Annulée
  date              DateTime            @default(now())
  dateEcheance      DateTime?           // Date limite de paiement
  stripePaymentLink String?             // Lien de paiement Stripe Checkout
  stripeSessionId   String?             // Session Stripe pour suivi
  derniereRelanceNiveau Int             @default(0) // 0=aucune, 1=doux(J+3), 2=ferme(J+7), 3=mise en demeure(J+15)
  derniereRelanceDate DateTime?         // Date du dernier envoi de relance
  notes             String?             // Notes internes sur la facture
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([userId, numero])
  @@index([devisId])
  @@index([userId, statut])
  @@index([userId, createdAt])
  @@index([userId, dateEcheance])
  @@index([recurrenteId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  titre     String
  contenu   String
  categorie String?  // Chantier, Personnel, Idée, À faire
  couleur   String?  // violet, emerald, rose, amber
  epingle   Boolean  @default(false)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categorie])
}

model ProspectMail {
  id        String   @id @default(cuid())
  email     String
  status    String   @default("Sent") // Sent, Failed, Bounced, Opened, Queued, Blocked
  source    String   @default("Manual") // Manual, Automated
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model ProspectDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  company   String?  // Nom de l'entreprise
  trade     String?  // Métier (peintre, plombier...)
  city      String?  // Ville
  source    String   @default("Manual") // Manual, Automated
  used      Boolean  @default(false) // Déjà utilisé par le robot
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([used])
  @@index([trade])
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Templates de devis ───

model DevisTemplate {
  id          String            @id @default(cuid())
  userId      String
  nom         String            // Nom du modèle (ex: "Rénovation salle de bain")
  description String?
  lignes      LigneTemplate[]   // Lignes du modèle
  tva         Float             @default(20)
  remise      Float             @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
}

model LigneTemplate {
  id             String        @id @default(cuid())
  templateId     String
  template       DevisTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  nomPrestation  String
  unite          String        @default("U")
  quantite       Float         @default(1)
  prixUnitaire   Float         @default(0)
  tva            String        @default("20")
  isOptional     Boolean       @default(false)
  position       Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([templateId])
}

// ─── Factures récurrentes ───

model FactureRecurrente {
  id            String    @id @default(cuid())
  userId        String
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  nom           String    // Nom du contrat (ex: "Entretien mensuel")
  montantHT     Float
  tva           Float     @default(20)
  montantTTC    Float
  frequence     String    // "mensuel", "trimestriel", "annuel"
  jourMois      Int       @default(1) // Jour du mois pour la facturation (1-28)
  prochaineDate DateTime  // Date de la prochaine facture
  dateFin       DateTime? // Date de fin (null = illimité)
  actif         Boolean   @default(true)
  description   String?
  factures      Facture[] // Factures générées
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([prochaineDate])
  @@index([actif])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "devis_signed" | "facture_paid" | "devis_overdue" | "client_added" | "milestone" | "system"
  title       String
  description String
  href        String?  // Lien vers la page concernée
  tone        String   @default("violet") // "violet" | "rose" | "amber" | "emerald" | "slate"
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}
