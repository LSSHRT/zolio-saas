{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "NODE_OPTIONS='--max-old-space-size=4096' npm run build",
  "crons": [
    {
      "path": "/api/cron/prospect",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/invoice-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/factures-recurrentes",
      "schedule": "0 2 * * *"
    }
  ]
}
